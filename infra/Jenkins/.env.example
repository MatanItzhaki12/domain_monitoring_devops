# Jenkins Environment Configuration
# Скопируйте этот файл в .env и заполните своими значениями

# Jenkins Admin Credentials
JENKINS_ADMIN_PASSWORD=admin123
JENKINS_DEVOPS_PASSWORD=devops123
JENKINS_DEV_PASSWORD=dev123

# Jenkins URL
JENKINS_URL=http://localhost:8080
JENKINS_ADMIN_EMAIL=admin@example.com

# Docker Hub Credentials
DOCKERHUB_USER=your-dockerhub-username
DOCKERHUB_PASS=your-dockerhub-password

# GitHub Credentials
GITHUB_USER=MatanItzhaki12
GITHUB_TOKEN=your-github-personal-access-token

# AWS Credentials (for Terraform)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Repository URL
REPO_URL=https://github.com/MatanItzhaki12/domain_monitoring_devops.git

# Jenkins Agent Secret (будет сгенерирован автоматически)
JENKINS_AGENT_SECRET=
