# Jenkins Environment Configuration
JENKINS_ADMIN_PASSWORD={{ jenkins_admin_password }}
JENKINS_DEVOPS_PASSWORD={{ jenkins_devops_password }}
JENKINS_DEV_PASSWORD={{ jenkins_dev_password }}

JENKINS_URL=http://{{ jenkins_url | default('localhost') }}:8080
JENKINS_ADMIN_EMAIL={{ jenkins_admin_email | default('admin@example.com') }}

DOCKERHUB_USER={{ dockerhub_user }}
DOCKERHUB_PASS={{ dockerhub_pass }}

GITHUB_USER={{ github_user }}
GITHUB_TOKEN={{ github_token }}

AWS_ACCESS_KEY_ID={{ aws_access_key_id | default('') }}
AWS_SECRET_ACCESS_KEY={{ aws_secret_access_key | default('') }}

REPO_URL={{ repo_url | default('https://github.com/MatanItzhaki12/domain_monitoring_devops.git') }}

JENKINS_AGENT_SECRET=
